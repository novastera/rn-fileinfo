{
  "name": "@novastera-oss/rn-fileinfo",
  "version": "0.4.0",
  "description": "Lightweight React Native TurboModule for safe and efficient file metadata access on iOS and Android. Part of Novastera's open-source ecosystem - a modern CRM/ERP SaaS platform.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "plugin",
    "*.podspec",
    "react-native.config.js",
    "expo-module.config.json",
    "app.plugin.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --build",
    "typecheck:watch": "tsc --build --watch",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "build:expo-plugin": "cd plugin && npm run build",
    "prepare": "bob build && npm run build:expo-plugin"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "file-info",
    "file-metadata",
    "filesystem",
    "turbo-module",
    "expo",
    "novastera",
    "crm",
    "erp",
    "saas",
    "document-management",
    "mobile-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/novastera/rn-fileinfo.git"
  },
  "author": "Hassan <hassan@novastera.com> (https://novastera.com)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/novastera/rn-fileinfo/issues"
  },
  "homepage": "https://github.com/novastera/rn-fileinfo#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.0.0",
    "@expo/config-plugins": "^56.0.0",
    "@react-native-community/cli": "^20.0.1",
    "@react-native/babel-preset": "~0.85.0",
    "@react-native/eslint-config": "~0.85.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^30.1.0",
    "prettier": "^3.0.3",
    "react": "^19.0.0",
    "react-native": "~0.85.0",
    "react-native-builder-bob": "^0.40.12",
    "turbo": "^2.5.6",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "expo": ">=49.0.0"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "tsc": "./node_modules/.bin/tsc"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RnFileinfoSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.novastera.rnfileinfo"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.54.2"
  },
  "expo": {
    "plugins": [
      "@novastera-oss/rn-fileinfo"
    ]
  }
}
